<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd
       http://www.springframework.org/schema/context
       http://www.springframework.org/schema/context/spring-context.xsd">

    <context:annotation-config/>

    <bean id="gamja" class="com.fw.week3.Food">
        <constructor-arg name="name" value="감자"/>
        <constructor-arg name="type" value="한식"/>
    </bean>

    <bean id="inseo" class="com.fw.week2.Person">
        <property name="name" value="김인서"/>
        <property name="age" value="27"/>
        <property name="gender" value="M"/>
        <property name="birthDate" value="2000-08-03"/>
        <property name="food" ref="gamja"/>
    </bean>

</beans>